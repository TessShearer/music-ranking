on.svg\"\n        alt=\"sidebar_illustration\"\n      />\n\n      <h6 v-if=\"isRTL\" class=\"mb-0 text-dark up\">تحتاج مساعدة ؟</h6>\n\n      <h6 v-else class=\"mb-0 text-dark up\">Need Help ?</h6>\n\n      <p v-if=\"isRTL\" class=\"text-xs font-weight-bold\">\n        يرجى التحقق من مستنداتنا\n      </p>\n\n      <p v-else class=\"text-xs font-weight-bold\">Please check our docs</p>\n    </div>\n\n    <a\n      v-if=\"isRTL\"\n      href=\"https://www.creative-tim.com/learning-lab/vue/overview/argon-dashboard/\"\n      target=\"_blank\"\n      class=\"mb-3 btn btn-dark btn-sm w-100\"\n    >\n      توثيق\n    </a>\n\n    <a\n      v-else\n      href=\"https://www.creative-tim.com/learning-lab/vue/overview/argon-dashboard/\"\n      target=\"_blank\"\n      class=\"mb-3 btn btn-dark btn-sm w-100\"\n    >\n      Documentation\n    </a>\n\n    <a\n      v-if=\"isRTL\"\n      href=\"https://www.creative-tim.com/product/vue-argon-dashboard-pro\"\n      target=\"_blank\"\n      class=\"mb-3 btn btn-success btn-sm w-100\"\n    >\n      التطور للاحترافية\n    </a>\n\n    <a\n      v-else\n      href=\"https://www.creative-tim.com/product/vue-argon-dashboard-pro\"\n      target=\"_blank\"\n      class=\"mb-3 btn btn-success btn-sm w-100\"\n    >\n      Upgrade to pro\n    </a>\n  </div>\n</template>\n"],"mappings":";AACA,SAASA,QAAQ,QAAQ,KAAK;AAC9B,SAASC,QAAQ,QAAQ,MAAM;;;;;;;;;;;;;;;;;;;;IAC/B,IAAMC,KAAK,GAAGD,QAAQ,CAAC,CAAC;IAExB,IAAME,KAAK,GAAGH,QAAQ,CAAC;MAAA,OAAME,KAAK,CAACE,KAAK,CAACD,KAAK;IAAA,EAAC;IAC/C,IAAME,MAAM,GAAGL,QAAQ,CAAC;MAAA,OAAME,KAAK,CAACE,KAAK,CAACC,MAAM;IAAA,EAAC","ignoreList":[]},"metadata":{},"sourceType":"module","externalDependencies":[]}